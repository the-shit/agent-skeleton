{
    "name": "jordanpartridge/agent-skeleton",
    "description": "Laravel 13 agent skeleton — base template for all Odin AI agents",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "hirethunk/verbs": "^1.0",
        "illuminate/redis": "*",
        "laravel/ai": "^0.3.1",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.0",
        "predis/predis": "^3.4",
        "prism-php/prism": "^0.99"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "laravel/telescope": "^5.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["artisan"]
}
