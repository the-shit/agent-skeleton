APP_NAME="Agent"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-agent.jordanpartridge.us
APP_TIMEZONE=America/Phoenix

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database — each agent gets its own PostgreSQL database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=your_agent
DB_USERNAME=your_agent
DB_PASSWORD=

# Redis — shared with Bifrost for pub/sub
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=null

QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Horizon
HORIZON_PREFIX=agent:

# AI — OpenRouter
OPENROUTER_API_KEY=
AGENT_MODEL=x-ai/grok-4-fast

# Slack
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=

# GitHub
GITHUB_TOKEN=
GITHUB_REPO=jordanpartridge/your-repo

# Bifrost
BIFROST_URL=https://bifrost.jordanpartridge.us
BIFROST_AGENT_SECRET=

# Qdrant — shared Odin vector store (knowledge-qdrant container)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=your-agent-name
QDRANT_EMBED_URL=http://127.0.0.1:11435
